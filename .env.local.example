# Supabase — get these from your Supabase project > Settings > API Keys
# Project URL: shown at the top of the API Keys page
# Publishable key: click "Create new API Keys" if not yet created, copy the sb_publishable_... value
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_your-key-here

# Copy this file to .env.local and fill in your values
